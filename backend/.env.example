PORT=3000

# postgres (matches docker-compose)
DATABASE_URL=postgresql://flashsale:flashsale@localhost:5432/flashsale?schema=public

# redis (AOF-persisted via docker-compose)
REDIS_URL=redis://localhost:6379

# admin is whoever logs in with this user id (demo-grade auth — see README)
ADMIN_USER_ID=admin123

# sale defaults used by the seed script (window derived from offset + duration)
SALE_PRODUCT_NAME=Limited Edition Item
SALE_TOTAL_STOCK=100
SALE_START_OFFSET_MINUTES=0
SALE_DURATION_MINUTES=60

# rate limit defaults — seeded into redis on first boot, tunable at runtime
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_ENABLED=true
